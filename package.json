{
  "name": "loccle",
  "version": "1.0.16",
  "description": "Terminal UI for Loccle powered by Mastra and OpenTUI.",
  "module": "index.ts",
  "type": "module",
  "bin": {
    "loccle": "bin/mastra-tui.ts",
    "mastra-tui": "bin/mastra-tui.ts"
  },
  "files": [
    "bin/**/*",
    "src/**/*.ts",
    "src/**/*.tsx",
    "index.ts",
    "tsconfig.json",
    "README.md"
  ],
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.0",
    "mastra": "^1.13.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "mastra dev",
    "build": "mastra build",
    "tui": "bun run src/tui/index.tsx",
    "start": "mastra start"
  },
  "dependencies": {
    "@mastra/core": "^1.42.0",
    "@mastra/duckdb": "^1.4.2",
    "@mastra/evals": "^1.3.0",
    "@mastra/libsql": "^1.13.0",
    "@mastra/loggers": "^1.1.2",
    "@mastra/memory": "^1.20.3",
    "@mastra/observability": "^1.14.1",
    "@opentui/core": "^0.4.1",
    "@opentui/react": "^0.4.1",
    "react": "^19.2.0",
    "react-devtools-core": "^7.0.1",
    "ws": "^8.18.0",
    "zod": "^4"
  }
}
